# ─────────────────────────────────────────────
#  DermAI — Environment Variables Template
#  Copy to .env and fill in real values
# ─────────────────────────────────────────────

# ── Flask ──────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-flask-key-change-me

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://dermai_user:dermai_pass@localhost:5432/dermai_db

# ── JWT ───────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-change-me
JWT_ACCESS_TOKEN_EXPIRES=86400

# ── AWS S3 ────────────────────────────────────
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_BUCKET=dermai-skin-images
AWS_REGION=us-east-1

# ── ML Model ──────────────────────────────────
MODEL_PATH=backend/ml/saved_models/efficientnet_dermai.h5
MOCK_INFERENCE=true

# ── OpenAI (Chatbot) ──────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── Frontend ──────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000
